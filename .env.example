# LLM — OpenAI or any OpenAI-compatible gateway (e.g. OpenRouter)
OPENAI_API_KEY=sk-...
# Optional: custom endpoint. Leave unset to use OpenAI directly.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Model id. For OpenAI: gpt-4o. For OpenRouter: openai/gpt-4o
OPENAI_MODEL=gpt-4o
# Max completion tokens per reply (raise on paid tiers; low avoids HTTP 402)
OPENAI_MAX_TOKENS=1500

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=kayfa_crm
