# LLM — OpenAI or any OpenAI-compatible gateway (e.g. Groq, OpenRouter)
# Groq is recommended for speed. Get a key at https://console.groq.com/keys
OPENAI_API_KEY=gsk_...
# Endpoint. Groq: https://api.groq.com/openai/v1 · OpenRouter: https://openrouter.ai/api/v1
# Leave unset to use OpenAI directly (a gsk_ key auto-routes to Groq).
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Model id. Groq: openai/gpt-oss-120b (streams tool calls reliably) · OpenAI: gpt-4o
OPENAI_MODEL=openai/gpt-oss-120b
# Max completion tokens per reply (raise on paid tiers; low avoids HTTP 402)
OPENAI_MAX_TOKENS=1500

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=kayfa_crm

# Manager login — gates the CRM + Performance dashboards.
# Auth is unified with end-users: a manager is a row in the MongoDB `users` table
# with role "manager", seeded from these vars on startup. Sign in with the EMAIL.
MANAGER_EMAIL=admin@kayfa.io
MANAGER_PASSWORD=change-me      # required to seed the manager account
MANAGER_NAME=Kayfa Manager     # optional display name

# ── Part 2: Monitoring & Optimization (all optional — sane defaults if unset) ──
# Embedding identity — used to count & price embedding tokens. Defaults match the
# local (free) SentenceTransformers model in src/rag/embeddings.py. Point these at
# a paid provider (e.g. EMBEDDING_PROVIDER=openai,
# EMBEDDING_MODEL=text-embedding-3-small) and embedding cost is priced correctly,
# even when the chat model is on a different provider.
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional pricing override (USD per 1M tokens). JSON; merged over the built-ins.
# MONITORING_PRICING_JSON={"chat": {"gpt-4o": [2.5, 10.0]}, "embedding": {"text-embedding-3-small": 0.02}}

# Optimizer thresholds (defaults shown) — above these a recommendation is raised.
RETRIEVAL_K=4
CHEAP_CHAT_MODEL=gpt-oss-20b
OPTIMIZATION_WINDOW=1000
OPT_MAX_TOOL_CALLS=2
OPT_MAX_INPUT_TOKENS=1500
OPT_MAX_CHUNKS=5
OPT_MAX_HISTORY=6
OPT_MAX_TOTAL_TOKENS=2500
OPT_HIGH_LATENCY_MS=6000
OPT_FAQ_REPEATS=3
